rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Every request must come from a signed-in user WHOSE EMAIL IS VERIFIED.
    // This is the server-side gate: an unverified (or fake) account can read and
    // write nothing, so clicking the email link is mandatory to use anything.
    function verified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function myEmail() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email;
    }
    // The other participant in a "uidA__uidB" chat id.
    function chatPeer(chatId) {
      return chatId.split('__')[0] == request.auth.uid
        ? chatId.split('__')[1] : chatId.split('__')[0];
    }

    match /users/{uid} {
      // Single-doc reads are fine (friend info, email lookup). Bulk listing is
      // capped at one result so nobody can harvest the whole user/email table.
      allow get: if verified();
      allow list: if verified() && request.query.limit <= 1;
      allow write: if verified() && request.auth.uid == uid;

      // Friend list: owner reads; owner writes their own; the invited person may
      // write into the inviter's list ONLY if a matching request exists.
      match /friends/{fid} {
        allow read: if verified() && request.auth.uid == uid;
        allow write: if verified() && (
          request.auth.uid == uid ||
          (request.auth.uid == fid &&
           exists(/databases/$(database)/documents/friendRequests/$(uid + '__' + fid)))
        );
      }
    }

    match /friendRequests/{id} {
      // get: a read of a NON-existent request must return not-found, not denied
      // (resource is null there) — the client's dup/reverse checks rely on that.
      allow get: if verified() && (resource == null ||
        resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      // list/delete stay scoped to the two parties so queries can't enumerate.
      allow list, delete: if verified() &&
        (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if verified() && request.resource.data.fromId == request.auth.uid;
    }

    match /invites/{id} {
      allow read, update, delete: if verified() &&
        (resource.data.fromId == request.auth.uid || resource.data.toEmail == myEmail());
      allow create: if verified() && request.resource.data.fromId == request.auth.uid;
    }

    match /lobby/{uid} {
      allow read: if verified();
      // Anyone verified may CLAIM a waiting player (that's the matchmaking
      // handshake), but only by writing the claim fields — not by rewriting
      // the waiter's name/rating.
      allow update: if verified() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['matchId', 'seed', 'targetDifficulty',
           'opponentID', 'opponentName', 'opponentRating']);
      allow create, delete: if verified() && request.auth.uid == uid;
    }

    // Participants (keys of the players map) can read/write. Async duels also
    // carry a `pids` array so "matches I'm in" can be queried
    // (where pids array-contains me) — that clause makes the query provably safe.
    function inMatch() {
      return request.auth.uid in resource.data.players ||
             request.auth.uid in resource.data.pids;
    }
    match /matches/{id} {
      allow read: if verified() && inMatch();
      // A participant may only ever write their OWN answer/result/applied
      // fields — never the opponent's, and never the deck or the rating
      // snapshots. This is what makes score forgery impossible server-side.
      allow update: if verified() && inMatch() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['answers_' + request.auth.uid,
           'result_' + request.auth.uid,
           'applied_' + request.auth.uid]);
      allow create: if verified() && request.auth.uid in request.resource.data.players;
      // Participants may clean up finished/withdrawn matches (async duels
      // delete themselves once both sides have applied the result).
      allow delete: if verified() && inMatch();
    }

    // Question-quality flags from the answer-review screen. Write-only for
    // clients (reviewed in the console); you can only file as yourself, and
    // only the expected fields — this can't be used as free-form storage.
    match /reports/{id} {
      allow create: if verified()
        && request.resource.data.by == request.auth.uid
        && request.resource.data.keys().hasOnly(['qid', 'by', 'createdAt'])
        && request.resource.data.qid is string
        && request.resource.data.qid.size() < 12;
    }

    // Daily challenge scores: a per-day leaderboard. Any verified player can read
    // the scores; you may only write your own.
    match /daily/{date}/scores/{uid} {
      allow read: if verified();
      allow write: if verified() && request.auth.uid == uid;
    }

    // Chat read receipts live on the chat doc as read_<uid> timestamps.
    // Same friends-only gate as the messages themselves.
    match /chats/{chatId} {
      allow read, write: if verified()
        && request.auth.uid in chatId.split('__')
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(chatPeer(chatId)));
    }

    // Chat: both must be participants of the id AND actually friends. Bodies are
    // E2E-encrypted ciphertext, and only friends can even fetch them. Messages
    // are immutable (no update/delete).
    match /chats/{chatId}/messages/{msgId} {
      allow read, create: if verified()
        && request.auth.uid in chatId.split('__')
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(chatPeer(chatId)));
    }
  }
}
